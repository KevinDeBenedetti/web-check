# Environment variables for Web-Check Security Scanner
# Copy this file to .env and adjust values as needed
#
# Development: Most defaults are suitable for local development
# Production: Review all settings before deploying

# ═══════════════════════════════════════════════════════════
# Environment
# ═══════════════════════════════════════════════════════════

# Set to true for development mode (more verbose logging, auto-reload)
DEBUG=false

# ═══════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════

API_TITLE="Web-Check Security Scanner"
API_VERSION="0.1.0"

# ==============================================================================
# Web-Check — environment variables reference
# Copy this file to .env and fill in your values.
# ==============================================================================

# ── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001                          # Change if 8001 is already taken
WEB_CHECK_CLI_API_URL=http://localhost:8001  # Must match API_PORT

# ── Allowed scan targets (old web-check API allowlist) ─────────────────────
ALLOWED_DOMAINS="example.com"

# ── my-check: web target ───────────────────────────────────────────────────
MY_CHECK_WEB_TARGET=https://example.com   # Default URL for web scans

# ── my-check: Kubernetes ───────────────────────────────────────────────────
# Run `kubectl config get-contexts` to list available contexts.
MY_CHECK_K8S_CONTEXT=                  # e.g. k3s, kind-local, my-cluster

# Absolute path to kubeconfig (blank = default ~/.kube/config)
MY_CHECK_K8S_KUBECONFIG=               # e.g. /home/you/.kube/config

# Override the Kubernetes API server URL (useful for remote k3s by IP)
MY_CHECK_K8S_SERVER=                   # e.g. https://192.168.1.10:6443

# Namespace scope (blank = all namespaces)
MY_CHECK_K8S_NAMESPACE=

# ── my-check: output ───────────────────────────────────────────────────────
MY_CHECK_OUTPUT=terminal               # terminal | json | html | webhook
MY_CHECK_OUTPUT_DIR=outputs
MY_CHECK_SARIF=false                   # Emit SARIF 2.1 alongside JSON output
MY_CHECK_WEBHOOK_URL=                  # Slack incoming webhook or custom URL

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Docker ─────────────────────────────────────────────────────────────────
DOCKER_NETWORK=scanner-net
OUTPUT_BASE_DIR=outputs
DEFAULT_TIMEOUT=300
MAX_TIMEOUT=3600

# ── ZAP (deep scanner) ─────────────────────────────────────────────────────
ZAP_HOST=zap
ZAP_PORT=8090

# ── CORS ───────────────────────────────────────────────────────────────────
# CORS_ORIGINS="http://localhost:3000,https://web-check.example.com"

# ═══════════════════════════════════════════════════════════
# Docker Configuration
# ═══════════════════════════════════════════════════════════

# Docker network for inter-container communication
DOCKER_NETWORK="scanner-net"

# Base directory for scan outputs
OUTPUT_BASE_DIR="outputs"

# ═══════════════════════════════════════════════════════════
# Scan Configuration
# ═══════════════════════════════════════════════════════════

# Default timeout for scans (in seconds)
DEFAULT_TIMEOUT=300

# Maximum allowed timeout (in seconds)
MAX_TIMEOUT=3600

# ═══════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Development: DEBUG
# Production: INFO or WARNING
LOG_LEVEL="INFO"

# ═══════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════

# SQLite database file path (relative to project root)
DATABASE_URL="sqlite+aiosqlite:///./web-check.db"

# ═══════════════════════════════════════════════════════════
# CORS (Cross-Origin Resource Sharing)
# ═══════════════════════════════════════════════════════════

# Allowed origins for CORS (comma-separated)
# Development: Use * for convenience
# Production: Set specific domains
# CORS_ORIGINS="http://localhost:3000,https://web-check.example.com"

# ═══════════════════════════════════════════════════════════
# Scanner Tools
# ═══════════════════════════════════════════════════════════

# ZAP Configuration
ZAP_HOST=zap
ZAP_PORT=8090

# Nuclei Configuration
NUCLEI_TEMPLATES_DIR="/root/nuclei-templates"

# ═══════════════════════════════════════════════════════════
# SSRF / Domain Allowlist
# ═══════════════════════════════════════════════════════════

# Comma-separated list of domains that the scanner is allowed to contact.
# Add every target domain you want to scan here.
# Also used by the CLI as default targets for `web-check check`.
ALLOWED_DOMAINS="example.com"

# ═══════════════════════════════════════════════════════════
# Development Only
# ═══════════════════════════════════════════════════════════

# Web dev server URL (for API to know where frontend is)
# Only used in development with docker-compose.dev.yml
VITE_API_URL="http://localhost:8000"
